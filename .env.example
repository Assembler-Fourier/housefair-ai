# Public site/app URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
HOUSEFAIR_ACCESS_MODE=free
LEGACY_PRIVATE_APP_ENABLED=false

# Supabase Auth + database. Service role stays server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# New Supabase key aliases are also supported server-side:
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Stripe Billing. Use test mode first; never commit secret or live keys.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY_EUR=
STRIPE_PRICE_YEARLY_EUR=
STRIPE_TAX_ENABLED=false

# Admin and maintenance controls
ADMIN_EMAILS=
MAINTENANCE_SECRET=

# Internal scheduled route protection. Vercel Cron sends this as a Bearer token.
CRON_SECRET=
HOUSEFAIR_CRON_SECRET=

# Public key is intentionally browser-readable; private key stays server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:housefair@example.com

OPENAI_API_KEY=
OPENAI_MODEL=
